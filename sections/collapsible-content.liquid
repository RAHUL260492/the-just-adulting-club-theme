
<div class="section-collapsible-content">
  {% if section.settings.heading %}
    <h2>{{ section.settings.heading }}</h2>
  {% endif %}
  <!-- Content for collapsible-content -->
</div>
{% schema %}
{
  "name": "collapsible content",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "collapsible content"
    }
  ],
  "presets": [
    {
      "name": "collapsible content"
    }
  ]
}
{% endschema %}
