<div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" data-alt="Close up of high quality dress socks on a wooden floor" style="background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuD3ODSCpfCjs-CCv4qmXZ8lz1N3yMp_p2nqVBdn1-y6Siz_L3HbAbGColm3q3WUnJ-DyJiQaJyrlN2iQhdl9M6VEv-flLduvx-kBv7EJKlmpSEHhuJ0lwfWTGk-ek-9SDCw-zhpXRGCrkDiOXzQvt7D0jC_chvuMvi8_URk5U7xz2l6iEr5IAILj4mEEfltwf-XSGTa5DP-dwvvDMsWBDfAJHgWE37aGDZR1DVyK9pvBauvJk29X5gphq4FiGMq4_73TrkdW5ARRx0&quot;);">
</div>
<div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
<div class="absolute inset-0 flex flex-col justify-end p-8 lg:p-16 text-white">
<p class="text-xs uppercase tracking-[0.3em] mb-3 opacity-80">Featured Selection</p>
<h3 class="font-display text-3xl md:text-5xl mb-6">Anti-Odour Dress Socks</h3>
<div class="flex items-center gap-4">
<button class="bg-primary hover:bg-primary/90 text-white px-8 py-3 rounded-full text-xs uppercase tracking-widest transition-all">
                            Shop Collection
                        </button>
<span class="text-sm italic font-display border-b border-white/40 pb-1 cursor-pointer hover:border-white transition-all">View Details</span>
</div>
</div>
</div>
<!-- 2. LIMITED EDITION CASUAL SOCKS (Spans 7 columns) -->
