
<section class="mx-auto w-full max-w-7xl grow px-6 py-20 lg:px-10">
<!-- Page Title -->
<div class="mb-24 text-center">
<h2 class="font-serif text-5xl md:text-7xl font-light text-brand-text dark:text-slate-100">
                    Our Collections
                </h2>
<div class="mx-auto mt-8 h-px w-24 bg-primary/30"></div>
<p class="mt-8 text-brand-text/60 dark:text-slate-400 max-w-lg mx-auto leading-relaxed">
                    A curated selection of timeless essentials designed for the discerning individual. Quality materials met with meticulous craftsmanship.
                </p>
</div>
<!-- 3-Column Grid -->
<div class="grid grid-cols-1 gap-x-8 gap-y-16 md:grid-cols-2 lg:grid-cols-3">
{% for collection in collections %}
{% unless collection.handle == 'all' or collection.handle == 'frontpage' %}
<div class="group flex flex-col">
<a href="{{ collection.url }}" class="aspect-[4/5] overflow-hidden rounded-lg bg-gray-100 block">
{% if collection.image %}
<img alt="{{ collection.title | escape }}" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" src="{{ collection.image | image_url: width: 600 }}" width="600" height="750" loading="lazy"/>
{% else %}
{% if collection.products.first and collection.products.first.featured_image %}
<img alt="{{ collection.title | escape }}" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" src="{{ collection.products.first.featured_image | image_url: width: 600 }}" width="600" height="750" loading="lazy"/>
{% else %}
<div class="h-full w-full bg-primary/10 flex items-center justify-center">
<span class="material-symbols-outlined text-primary text-5xl">collections_bookmark</span>
</div>
{% endif %}
{% endif %}
</a>
<div class="mt-6 flex flex-col items-start">
<h3 class="collection-title-caps text-brand-text dark:text-slate-100">{{ collection.title | upcase }}</h3>
<a class="mt-2 flex items-center gap-1 text-sm font-medium text-primary transition group-hover:gap-2" href="{{ collection.url }}">
                            Explore 
                            <span class="material-symbols-outlined text-base">arrow_right_alt</span>
</a>
</div>
</div>
{% endunless %}
{% endfor %}
</div>
</section>

{% schema %}
{
  "name": "Collection List",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Collections"
    }
  ],
  "presets": [
    {
      "name": "Collection List"
    }
  ]
}
{% endschema %}
