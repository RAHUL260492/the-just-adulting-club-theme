<div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110" data-alt="Lifestyle shot of colorful patterned socks on feet" style="background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuBWnTb3jAdgi3ozf-iyqjyH4QXOzl-QpApIipQSqsILOxr65-4Nohjg8qO8cze_xGufap7SduPu_sDBWoucYEUxIXAdNt--RnHARL0gX4vjQSD7p2C8M_lVKlafVPxG9N5L_NkXoBDtgiiUePq23r_tO3aBm_u1G6oYPqRlR-Ik25B27YuyWYortjjiHcD6TwzuN7QTZPF7I7kGFmQ48C8oOjv-fSMSXv6zHy5C9txvnq69gAMy4mMTigCPRAt7DflnR80B1L4f_aY&quot;);">
</div>
<div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors"></div>
<div class="absolute inset-0 flex flex-col items-center justify-center text-white text-center p-6">
<h3 class="font-display text-3xl lg:text-4xl tracking-wide">Limited Edition Casual</h3>
<div class="w-0 group-hover:w-16 h-px bg-white mt-4 transition-all duration-500 overflow-hidden"></div>
</div>
</div>
<!-- 3. CUBAN & RESORT SHIRTS (Spans 5 columns) -->
<div class="lg:col-span-5 group relative overflow-hidden rounded-lg aspect-[4/5] bg-slate-200 lg:mt-12">
<div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" data-alt="Man wearing a breathable resort style shirt on vacation" style="background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuBgAsTDQD7wyKKfVcdbFDyzs33fkEp-QMEGSxvtGzpcI3x9ao2QuhrsLqBFWipT0AQsY2jMt2DkcxfV4kYD_4p5t21RZrIzlCKKKqauWbzi84jR7rL8Iyjb_70aMR-FbEw5T-ogeE_XMgalPn7XmsGlsfOTD5R-fN4LXtrCWbAZZuV80ZZ1Nykpm9Yz7W9pBynlpNGrhHXODW4sLessetWEV2lDvR1YIDZeKdwWtmpMdTqNwyyUCmh3Bo-DSJEnF3pkDUL3ZzOpJoA&quot;);">
</div>
<div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/70"></div>
<div class="absolute inset-0 flex flex-col justify-end items-center p-10 text-white">
<h3 class="font-display text-2xl lg:text-3xl mb-2">Cuban &amp; Resort Shirts</h3>
<p class="text-[10px] uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-opacity duration-300">Breathable Essentials</p>
</div>
</div>
<!-- 4. SIGNATURE POLOS (Spans 5 columns) -->
<div class="lg:col-span-5 group relative overflow-hidden rounded-lg aspect-[1/1] bg-slate-200">
<div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:rotate-1 group-hover:scale-110" data-alt="Folded premium polo shirts in various earthy colors" style="background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuBhGg05HKvVxnmSDFD5pUXdw2SEN9CIxBBXuoz19JRQJWtilFJJrC3I5SWWWmfdwXh_7fW87t-C7zO3IdyRp73MWbma22LwFPnEjr22k6lDrtf-i5QuEOEgUlvA1D_wKIfOaAfHFlhmYhCqd6JAq-xfuuvkQ8Pwz599Tj8PM2j_2ez4_-sXYb6aEvn7uRK0yRRmD4rBzxRkcMT7Q3m5nrbMwtdF-DKDyhAO0cO9V630zAXBaVJfAjXAzAMqdZBrAu5cUUuyDV4qmCM&quot;);">
</div>
<div class="absolute inset-0 bg-black/10 group-hover:bg-black/40 transition-all flex items-center justify-center">
<h3 class="font-display text-3xl text-white opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500">Signature Polos</h3>
</div>
<div class="absolute bottom-6 left-6 text-white">
<span class="font-display italic text-lg group-hover:opacity-0 transition-opacity">The Polo Edit</span>
</div>
</div>
<!-- 5. LINEN SHIRTS (Spans 7 columns) -->
<div class="lg:col-span-7 group relative overflow-hidden rounded-lg aspect-[16/10] bg-slate-200 lg:-mt-12">
<div class="absolute inset-0 bg-cover bg-center transition-transform duration-1000 group-hover:scale-105" data-alt="Close up of a premium linen fabric texture shirt" style="background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuDNjURNwIVMUvsnGah-71OWtJG8S8WU8nxDPfqrCTrRbL2luVE2ClaPLRXOYB7xWlWSQud8gwgZ_yKkPSNBjPSKXzszzrACgEaC107AoBdzTQncAiWw8h8_0PYdr5nSpdwpwuA-L6EO4r64bZ0Pdk-V01yQacGdtUupAfRa2fV6O1w0uypRcf6KNag9OOSiIkaGiS0RRbYULyIqfaG5ThF4Z_haoChioalwD1tn7hdODEgUkbgN6Ko_3EnpdspDWigDUzSL1fKRlVs&quot;);">
</div>
<div class="absolute inset-0 bg-gradient-to-r from-black/40 to-transparent"></div>
<div class="absolute inset-0 flex flex-col justify-center p-12 text-white">
<h3 class="font-display text-4xl mb-4">Linen Shirts</h3>
<p class="max-w-xs text-sm opacity-90 leading-relaxed font-light mb-6">Designed for those who value comfort as much as style.</p>
<a class="inline-flex items-center gap-2 group/btn" href="#">
<span class="text-xs uppercase tracking-widest border-b border-white pb-1">Shop Linen</span>
<span class="material-symbols-outlined text-sm group-hover/btn:translate-x-2 transition-transform">trending_flat</span>
</a>
</div>
</div>
<!-- 6. NEW ARRIVALS (Spans 12 columns / Banner) -->
<div class="lg:col-span-12 group relative overflow-hidden rounded-lg py-24 bg-primary/10 flex flex-col items-center justify-center text-center px-6">
<div class="absolute inset-0 opacity-10 pointer-events-none overflow-hidden">
<span class="material-symbols-outlined text-[20rem] absolute -top-20 -left-20 text-primary rotate-12">auto_awesome</span>
<span class="material-symbols-outlined text-[15rem] absolute -bottom-10 -right-10 text-primary -rotate-12">flare</span>
</div>
<p class="text-xs uppercase tracking-[0.4em] mb-4 text-primary font-bold">Just In</p>
<h2 class="font-display text-4xl md:text-6xl mb-8 dark:text-slate-100">The New Arrivals</h2>
<p class="max-w-lg mb-10 text-slate-600 dark:text-slate-400 text-sm md:text-base leading-relaxed">Discover our latest pieces, where timeless design meets modern functionality. Crafted for the professional on the move.</p>
<button class="border-2 border-primary text-primary hover:bg-primary hover:text-white px-12 py-4 rounded-full text-xs uppercase tracking-widest font-bold transition-all duration-300">
                    Explore Newest Additions
                </button>
</div>
</div>
<!-- Newsletter Section -->
<section class="mt-32 pt-20 border-t border-primary/20">
<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
<div>
<h4 class="font-display text-3xl mb-4">Join The Club</h4>
<p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed max-w-sm">Receive exclusive access to new collection launches, editorial content, and club-only events.</p>
</div>
<form class="flex flex-col sm:flex-row gap-4">
<input class="flex-grow bg-white dark:bg-slate-800 border-primary/20 focus:border-primary focus:ring-0 rounded-lg px-6 py-4 text-sm font-light" placeholder="Email Address" type="email">
<button class="bg-primary text-white px-10 py-4 rounded-lg text-xs uppercase tracking-widest font-bold hover:bg-primary/90 transition-colors" type="submit">Subscribe</button>
</form>
</div>
</section>
</section>

