
<section>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-32 items-start">
<!-- Left Column: Contact Details -->
<div class="space-y-12">
<div class="space-y-6">
<h2 class="font-serif text-5xl lg:text-7xl text-neutral-dark leading-tight">Get in Touch</h2>
<p class="font-body text-lg text-neutral-soft max-w-md leading-relaxed">
                        Whether you have a question about our sizing, need assistance with an order, or just want to say hello, we're here to help.
                    </p>
</div>
<div class="space-y-10">
<!-- Support Email -->
<div class="flex flex-col gap-2 group cursor-pointer">
<span class="text-xs font-bold uppercase tracking-widest text-primary/60 font-display">Support Email</span>
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-primary">mail</span>
<a class="text-xl font-body text-neutral-dark hover:text-primary transition-colors" href="mailto:hello@justadultingclub.com">hello@justadultingclub.com</a>
</div>
</div>
<!-- Office Address -->
<div class="flex flex-col gap-2">
<span class="text-xs font-bold uppercase tracking-widest text-primary/60 font-display">Office Address</span>
<div class="flex items-start gap-3">
<span class="material-symbols-outlined text-primary">location_on</span>
<p class="text-xl font-body text-neutral-dark leading-relaxed">
                                123 Artisan Way, Suite 400<br>
                                New York, NY 10012
                            </p>
</div>
</div>
<!-- Social Media -->
<div class="flex flex-col gap-4">
<span class="text-xs font-bold uppercase tracking-widest text-primary/60 font-display">Follow Us</span>
<div class="flex gap-6">
<a class="flex items-center gap-2 group" href="{{ routes.all_products_collection_url }}">
<span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">photo_camera</span>
<span class="font-body text-neutral-dark group-hover:text-primary transition-colors">Instagram</span>
</a>
<a class="flex items-center gap-2 group" href="{{ routes.all_products_collection_url }}">
<span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">alternate_email</span>
<span class="font-body text-neutral-dark group-hover:text-primary transition-colors">Twitter</span>
</a>
</div>
</div>
</div>
<!-- Subtle Decorative Image -->
<div class="pt-8 opacity-80">
<img alt="Elegant office space with soft lighting" class="rounded-xl w-full h-48 object-cover shadow-sm" data-alt="Minimalist interior of a luxury office with plants" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAH-Ri4JaDOxILWahXVpFNQoFhC_Rv1nwM4z6trGDJZCFTAOXJpfgVQtCULyL4KPeIRYB3cUZz-TJQSEP8oEp77UQmWhcbhtRRltsucGOSMXQQ-SlPZQKFxegVnW1hLuK1AsHBuLQBJDm74XH6qHe7VqtqwVs1DqCc4b1_6u2Qiar9Glv99FkLPXd_RrdH4BNdbl7Ei_RgnyjQ_BU27kPdMKq2ks64aXJfRoQ7NvYTWmW8l1aaGA4cfb-wnBpnvcGot3Qv6AGFUiJE">
</div>
</div>
<!-- Right Column: Contact Form -->
<div class="bg-white p-8 lg:p-12 rounded-2xl shadow-xl shadow-primary/5 border border-primary/5">
<form class="space-y-8">
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="space-y-2">
<label class="text-sm font-medium text-neutral-soft font-display" for="name">Full Name</label>
<input class="w-full bg-background-light border-0 rounded-lg p-4 focus:ring-2 focus:ring-primary/40 text-neutral-dark placeholder:text-neutral-soft/50 transition-all font-body" id="name" name="name" placeholder="John Doe" type="text">
</div>
<div class="space-y-2">
<label class="text-sm font-medium text-neutral-soft font-display" for="email">Email Address</label>
<input class="w-full bg-background-light border-0 rounded-lg p-4 focus:ring-2 focus:ring-primary/40 text-neutral-dark placeholder:text-neutral-soft/50 transition-all font-body" id="email" name="email" placeholder="email@example.com" type="email">
</div>
</div>
<div class="space-y-2">
<label class="text-sm font-medium text-neutral-soft font-display" for="phone">Phone Number</label>
<input class="w-full bg-background-light border-0 rounded-lg p-4 focus:ring-2 focus:ring-primary/40 text-neutral-dark placeholder:text-neutral-soft/50 transition-all font-body" id="phone" name="phone" placeholder="+1 (555) 000-0000" type="tel">
</div>
<div class="space-y-2">
<label class="text-sm font-medium text-neutral-soft font-display" for="message">Your Message</label>
<textarea class="w-full bg-background-light border-0 rounded-lg p-4 focus:ring-2 focus:ring-primary/40 text-neutral-dark placeholder:text-neutral-soft/50 transition-all font-body resize-none" id="message" name="message" placeholder="Tell us how we can help..." rows="5"></textarea>
</div>
<button class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-5 rounded-lg shadow-lg shadow-primary/20 transition-all active:scale-[0.98] flex items-center justify-center gap-2" type="submit">
<span>Send Message</span>
<span class="material-symbols-outlined text-sm">send</span>
</button>
</form>
<p class="mt-6 text-center text-xs text-neutral-soft font-body italic">
                    Typical response time: Within 24 hours.
                </p>
</div>
</div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
