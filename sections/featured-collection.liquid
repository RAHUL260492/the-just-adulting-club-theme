
<section class="max-w-7xl mx-auto px-6 py-24">
<div class="flex flex-col md:flex-row items-end justify-between mb-12 gap-4">
<div class="max-w-lg">
<span class="text-primary font-bold uppercase tracking-widest text-xs mb-2 block">Curated Styles</span>
<h3 class="serif-heading text-4xl font-bold">Featured Collections</h3>
</div>
<a class="text-sm font-bold uppercase tracking-widest border-b border-primary pb-1 hover:text-primary transition-colors" href="{{ routes.collections_url }}">View All Collections</a>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
{% for collection in collections limit: 3 %}
{% unless collection.handle == 'all' or collection.handle == 'frontpage' %}
<a href="{{ collection.url }}" class="group cursor-pointer block">
<div class="aspect-[3/4] overflow-hidden mb-4 rounded-lg bg-surface">
{% if collection.image %}
<img alt="{{ collection.title | escape }}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="{{ collection.image | image_url: width: 600 }}" width="600" height="800" loading="lazy">
{% else %}
<div class="w-full h-full bg-primary/10 flex items-center justify-center">
<span class="material-symbols-outlined text-primary text-6xl">collections_bookmark</span>
</div>
{% endif %}
</div>
<h4 class="serif-heading text-xl font-bold mb-1 group-hover:text-primary transition-colors">{{ collection.title }}</h4>
<p class="text-slate-500 text-sm font-medium uppercase tracking-wider">{{ collection.products_count }} products</p>
</a>
{% endunless %}
{% endfor %}
</div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collections"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
