
<header class="sticky-header">
<div class="max-w-7xl mx-auto flex items-center justify-between">
<!-- Navigation Links -->
<nav class="hidden lg:flex items-center gap-8 text-sm font-medium tracking-tight uppercase">
<a class="hover:text-primary transition-colors" href="{{ routes.all_products_collection_url }}?sort_by=created-descending">New Arrivals</a>
<a class="hover:text-primary transition-colors" href="{{ routes.all_products_collection_url }}">Shop All</a>
<a class="hover:text-primary transition-colors" href="{{ routes.collections_url }}">Collections</a>
</nav>
<!-- Logo -->
<div class="flex flex-col items-center">
<a href="{{ routes.root_url }}" class="serif-heading text-2xl lg:text-3xl font-bold tracking-tighter text-primary">
                    {{ shop.name }}
                </a>
</div>
<!-- Icons/Utilities -->
<div class="flex items-center gap-6">
<a href="{{ routes.search_url }}" class="flex items-center hover:text-primary transition-colors">
<span class="material-symbols-outlined text-2xl">search</span>
</a>
<a href="{{ routes.account_login_url }}" class="flex items-center hover:text-primary transition-colors">
<span class="material-symbols-outlined text-2xl">person</span>
</a>
<a href="{{ routes.cart_url }}" class="relative flex items-center hover:text-primary transition-colors">
<span class="material-symbols-outlined text-2xl">shopping_bag</span>
<span class="absolute -top-1 -right-1 bg-primary text-white text-[10px] rounded-full h-4 w-4 flex items-center justify-center font-bold">{{ cart.item_count }}</span>
</a>
<button class="lg:hidden flex items-center">
<span class="material-symbols-outlined text-2xl">menu</span>
</button>
</div>
</div>
</header>

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Menu"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
