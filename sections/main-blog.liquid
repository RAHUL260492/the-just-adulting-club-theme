
<section>
<!-- Journal Title Section -->
<div class="text-center mb-24">
<h2 class="font-display text-7xl md:text-9xl font-extralight tracking-tight mb-6">The Journal</h2>
<div class="w-12 h-[1px] bg-primary mx-auto mb-6"></div>
<p class="max-w-xl mx-auto text-text-muted dark:text-slate-400 text-lg font-light leading-relaxed">
                    A curated collection of stories on luxury, lifestyle, and the quiet art of modern adulting.
                </p>
</div>
<!-- Categories Filter -->
<div class="flex flex-wrap justify-center gap-8 mb-16 border-y border-primary/5 py-6">
<a class="text-xs font-bold uppercase tracking-[0.2em] text-primary" href="{{ routes.all_products_collection_url }}">All Stories</a>
<a class="text-xs font-medium uppercase tracking-[0.2em] text-text-muted hover:text-primary transition-colors" href="{{ routes.all_products_collection_url }}">Style</a>
<a class="text-xs font-medium uppercase tracking-[0.2em] text-text-muted hover:text-primary transition-colors" href="{{ routes.all_products_collection_url }}">Living</a>
<a class="text-xs font-medium uppercase tracking-[0.2em] text-text-muted hover:text-primary transition-colors" href="{{ routes.all_products_collection_url }}">Culture</a>
<a class="text-xs font-medium uppercase tracking-[0.2em] text-text-muted hover:text-primary transition-colors" href="{{ routes.all_products_collection_url }}">Interviews</a>
</div>
<!-- Editorial Grid (2 Columns) -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-24">
<!-- Card 1 -->
<article class="group flex flex-col gap-8">
<div class="overflow-hidden aspect-[3/4] bg-primary/5">
<img alt="Luxury linen apparel" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" data-alt="Editorial shot of a beige linen shirt hanging in sunlight" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA2k8bfmPggETF0VjVpamhJGwWRzJPJEIVMZK99-Tl7TsdTpKlBPqB87lYONUZBDCvS-p4xp4kXZawvDKpXVKZAWJrHsZz6vW-v8FEbTOjdu0v7XcGNbSWCwUvbuXQybUDUqezhGs2YxEsmqv4c509lH0yL8z3WL_pcYSX9R-9tTnMFIJNVV9LCbtT3z5GdWcuOD9iA7b3larUADCHjTijKppOrgjBcLTGQ1pYJXeQHWrOY1ZKHuyulQfEE4ypqcQcnDo2GdR3lUwg">
</div>
<div class="flex flex-col gap-4">
<div class="flex items-center gap-3">
<span class="text-[10px] font-bold uppercase tracking-[0.3em] text-primary">Style</span>
<span class="text-[10px] text-text-muted dark:text-slate-500 uppercase tracking-[0.2em]">Oct 12, 2023</span>
</div>
<h3 class="font-display text-4xl leading-tight group-hover:text-primary transition-colors">
                            Wardrobe Essentials for the Modern Adult
                        </h3>
<p class="text-text-muted dark:text-slate-400 font-light leading-relaxed line-clamp-2">
                            Exploring the foundation of a timeless wardrobe that transcends seasonal trends, focusing on quality over quantity.
                        </p>
<a class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest mt-2 group-hover:gap-4 transition-all" href="{{ routes.all_products_collection_url }}">
                            Read Story <span class="material-symbols-outlined text-sm">arrow_forward</span>
</a>
</div>
</article>
<!-- Card 2 -->
<article class="group flex flex-col gap-8 md:mt-20">
<div class="overflow-hidden aspect-[3/4] bg-primary/5">
<img alt="Minimalist closet space" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" data-alt="A minimalist white closet with three perfectly spaced items" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCmT6xgUmqSjJxIskDf8aoa8YVvpId6DqTmAAOJw-_SUgP3uGTMvLlKiOhhiakBvieHJf0pTuwzhF0_bud4p2qcgnlMFz7ODLiBc36uSAGdQ0_0wBZm1hac6gnZUDgitLR8VN0-XueT6TkMAT0MDiEt-4Bv2G4OX29eAt-QO82dAHnB9aeigO2MpZfhMe38uwn9d9zQ7mkDq_KDynqJKvoIYuQdeJ4Lllxomq7uZ0_Zc8DFnI67N1FBcHPLZC8G0ncsNusDGvDaqn4">
</div>
<div class="flex flex-col gap-4">
<div class="flex items-center gap-3">
<span class="text-[10px] font-bold uppercase tracking-[0.3em] text-primary">Lifestyle</span>
<span class="text-[10px] text-text-muted dark:text-slate-500 uppercase tracking-[0.2em]">Sep 28, 2023</span>
</div>
<h3 class="font-display text-4xl leading-tight group-hover:text-primary transition-colors">
                            The Art of Curating a Minimalist Closet
                        </h3>
<p class="text-text-muted dark:text-slate-400 font-light leading-relaxed line-clamp-2">
                            How to strip back your collection to the pieces that truly matter and inspire daily confidence.
                        </p>
<a class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest mt-2 group-hover:gap-4 transition-all" href="{{ routes.all_products_collection_url }}">
                            Read Story <span class="material-symbols-outlined text-sm">arrow_forward</span>
</a>
</div>
</article>
<!-- Card 3 -->
<article class="group flex flex-col gap-8">
<div class="overflow-hidden aspect-[3/4] bg-primary/5">
<img alt="Sustainable fabrics texture" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" data-alt="Close up of organic cotton fabric texture in olive green" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAT-azrxzJKsGwxuE-Ul_sR0BECdz8PccrP_QjWLMCRwDq8KvH1ZY38nSvvmKWzPQm-ASkWThO2PI2fUJju-yluqzS0zBHH7g9GLXRPoLpcgIMNGIfOvQH6n7jW14JtAKgTfrehsSI_y5uW68RgUqy2gcwVq9JoF_9MSuAXRL0Frney8tV0_YYuLFju_95qvun6meGSNZFZw170eU__mmVsIznGKxthl2_-I3Rt5bQNHKtKgnm-xhSEJQsOWEtHsbDWjbUemXRq4gc">
</div>
<div class="flex flex-col gap-4">
<div class="flex items-center gap-3">
<span class="text-[10px] font-bold uppercase tracking-[0.3em] text-primary">Culture</span>
<span class="text-[10px] text-text-muted dark:text-slate-500 uppercase tracking-[0.2em]">Sep 15, 2023</span>
</div>
<h3 class="font-display text-4xl leading-tight group-hover:text-primary transition-colors">
                            Sustainable Luxury: The Future of Fabrics
                        </h3>
<p class="text-text-muted dark:text-slate-400 font-light leading-relaxed line-clamp-2">
                            A deep dive into the ethical sourcing of our signature organic cotton and the evolution of sustainable luxury.
                        </p>
<a class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest mt-2 group-hover:gap-4 transition-all" href="{{ routes.all_products_collection_url }}">
                            Read Story <span class="material-symbols-outlined text-sm">arrow_forward</span>
</a>
</div>
</article>
<!-- Card 4 -->
<article class="group flex flex-col gap-8 md:mt-20">
<div class="overflow-hidden aspect-[3/4] bg-primary/5">
<img alt="Morning ritual coffee" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" data-alt="Morning coffee cup on a wooden table with soft shadows" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAKY_kptNKSjG2oXez0Dfvju4KxCveaZ1z2mK4F_RP75fPn8SiQsFLv5Cl5kqCOKZ-RB2Q1-jlRkq4fG3T5ljTRM7XJborIoG6U6_xvFSJGIrhnJ0NkieX5FA6ez_50seoJkKSYIHDsuy3Fcppw_d7wIxRmg08vUpUm9JwReitIrceyGyoLf5LfT6ykRoX_9yDRxKUiVjaOkd2RoERqU3sYltlPSDWLr-v7p90j-GlS8va7tssP7lAY57T_8Uz-EZUKoCCZO4MQRqY">
</div>
<div class="flex flex-col gap-4">
<div class="flex items-center gap-3">
<span class="text-[10px] font-bold uppercase tracking-[0.3em] text-primary">Interviews</span>
<span class="text-[10px] text-text-muted dark:text-slate-500 uppercase tracking-[0.2em]">Sep 02, 2023</span>
</div>
<h3 class="font-display text-4xl leading-tight group-hover:text-primary transition-colors">
                            Morning Rituals: Finding Calm in the Chaos
                        </h3>
<p class="text-text-muted dark:text-slate-400 font-light leading-relaxed line-clamp-2">
                            Establishing a routine that sets the tone for a productive, mindful day in a fast-paced world.
                        </p>
<a class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest mt-2 group-hover:gap-4 transition-all" href="{{ routes.all_products_collection_url }}">
                            Read Story <span class="material-symbols-outlined text-sm">arrow_forward</span>
</a>
</div>
</article>
</div>
<!-- Load More Section -->
<div class="mt-32 text-center">
<button class="px-12 py-5 bg-primary text-white text-xs font-bold uppercase tracking-[0.3em] hover:bg-primary/90 transition-all shadow-lg shadow-primary/20">
                    Load More Articles
                </button>
</div>
</section>

