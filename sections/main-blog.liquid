<section class="max-w-[1200px] mx-auto px-6 lg:px-10 py-16 lg:py-24">
<!-- Journal Title Section -->
<div class="text-center mb-24">
<h2 class="font-serif text-7xl md:text-9xl font-extralight tracking-tight mb-6">{{ blog.title | default: "The Journal" }}</h2>
<div class="w-12 h-[1px] bg-primary mx-auto mb-6"></div>
<p class="max-w-xl mx-auto text-slate-500 dark:text-slate-400 text-lg font-light leading-relaxed">
    A curated collection of stories on luxury, lifestyle, and the quiet art of modern adulting.
</p>
</div>

<!-- Categories Filter -->
<div class="flex flex-wrap justify-center gap-8 mb-16 border-y border-primary/5 py-6">
<a class="text-xs font-bold uppercase tracking-[0.2em] {% if current_tags == blank %}text-primary{% else %}text-slate-500 hover:text-primary transition-colors{% endif %}" href="{{ blog.url }}">All Stories</a>
{% for tag in blog.all_tags %}
<a class="text-xs font-medium uppercase tracking-[0.2em] {% if current_tags contains tag %}text-primary font-bold{% else %}text-slate-500 hover:text-primary transition-colors{% endif %}" href="{{ blog.url }}/tagged/{{ tag | handleize }}">{{ tag }}</a>
{% endfor %}
</div>

<!-- Editorial Grid (2 Columns) -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-24">
{% for article in blog.articles %}
<article class="group flex flex-col gap-8 {% cycle '', 'md:mt-20' %}">
<a href="{{ article.url }}" class="overflow-hidden aspect-[3/4] bg-primary/5 block">
{% if article.image %}
<img alt="{{ article.title | escape }}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="{{ article.image | image_url: width: 800 }}" loading="lazy" width="600" height="auto">
{% else %}
<div class="w-full h-full bg-slate-200"></div>
{% endif %}
</a>
<div class="flex flex-col gap-4">
<div class="flex items-center gap-3">
{% if article.tags.size > 0 %}
<span class="text-[10px] font-bold uppercase tracking-[0.3em] text-primary">{{ article.tags.first }}</span>
{% endif %}
<span class="text-[10px] text-slate-500 dark:text-slate-400 uppercase tracking-[0.2em]">{{ article.published_at | date: "%b %d, %Y" }}</span>
</div>
<a href="{{ article.url }}">
<h3 class="font-serif text-4xl leading-tight group-hover:text-primary transition-colors">
    {{ article.title }}
</h3>
</a>
<p class="text-slate-500 dark:text-slate-400 font-light leading-relaxed line-clamp-2">
    {{ article.excerpt_or_content | strip_html | truncatewords: 30 }}
</p>
<a class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest mt-2 group-hover:gap-4 transition-all text-primary" href="{{ article.url }}">
    Read Story <span class="material-symbols-outlined text-sm">arrow_forward</span>
</a>
</div>
</article>
{% else %}
<div class="col-span-1 md:col-span-2 text-center py-20 text-slate-500">
    <p>No stories published yet.</p>
</div>
{% endfor %}
</div>

<!-- Pagination / Load More Section -->
{% if paginate.pages > 1 %}
<div class="mt-32 text-center">
    <a href="{{ paginate.next.url }}" class="inline-block px-12 py-5 bg-primary text-white text-xs font-bold uppercase tracking-[0.3em] hover:bg-primary/90 transition-all shadow-lg shadow-primary/20">
        Load More Articles
    </a>
</div>
{% endif %}
</section>

{% schema %}
{
  "name": "Blog Listing Grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Journal"
    }
  ],
  "presets": [
    {
      "name": "Main Blog"
    }
  ]
}
{% endschema %}
