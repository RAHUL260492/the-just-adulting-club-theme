<section class="max-w-7xl mx-auto px-6 lg:px-20 py-12">
<!-- Breadcrumb -->
<nav class="flex items-center gap-2 text-sm text-brand-text/60 mb-8 uppercase tracking-widest">
<a class="hover:text-brand-text" href="{{ routes.root_url }}">Home</a>
<span class="material-symbols-outlined text-xs">chevron_right</span>
<span class="text-brand-text">Cart</span>
</nav>
<h2 class="text-5xl lg:text-6xl serif-heading mb-12">Shopping Cart</h2>
<div class="flex flex-col lg:flex-row gap-16">
<!-- Cart Items Table -->
<div class="flex-grow">
{% if cart.item_count > 0 %}
<form action="{{ routes.cart_url }}" method="post" id="cart-form">
<div class="w-full overflow-x-auto">
<table class="w-full text-left border-collapse">
<thead>
<tr class="border-b border-primary/10 text-xs uppercase tracking-widest text-brand-text/50">
<th class="pb-6 font-medium">Product</th>
<th class="pb-6 font-medium px-4">Quantity</th>
<th class="pb-6 font-medium text-right">Total</th>
</tr>
</thead>
<tbody class="divide-y divide-primary/10">
{% for item in cart.items %}
<tr>
<td class="py-8">
<div class="flex gap-6">
<a href="{{ item.url }}" class="w-24 h-32 bg-slate-200 rounded-lg overflow-hidden flex-shrink-0 block">
{% if item.image %}
<img alt="{{ item.title | escape }}" class="w-full h-full object-cover" src="{{ item.image | image_url: width: 300 }}" width="300" height="400" loading="lazy">
{% endif %}
</a>
<div class="flex flex-col justify-between">
<div>
<a href="{{ item.url }}" class="font-medium text-lg hover:text-primary transition-colors">{{ item.product.title }}</a>
{% unless item.product.has_only_default_variant %}
<p class="text-brand-text/60 text-sm mt-1">{{ item.variant.title }}</p>
{% endunless %}
</div>
<a href="{{ item.url_to_remove }}" class="flex items-center w-fit gap-1 text-xs text-brand-text/40 hover:text-red-600 transition-colors mt-2">
<span class="material-symbols-outlined text-sm">close</span> Remove
</a>
</div>
</div>
</td>
<td class="py-8 px-4 align-top">
<div class="flex items-center border border-primary/20 rounded-lg w-fit">
<button type="button" class="px-3 py-1 hover:bg-primary/5 transition-colors text-primary" onclick="this.nextElementSibling.value = Math.max(0, parseInt(this.nextElementSibling.value) - 1); this.closest('form').submit();">-</button>
<input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="w-10 text-center text-sm font-medium border-none bg-transparent focus:ring-0 p-0" onchange="this.closest('form').submit();">
<button type="button" class="px-3 py-1 hover:bg-primary/5 transition-colors text-primary" onclick="this.previousElementSibling.value = parseInt(this.previousElementSibling.value) + 1; this.closest('form').submit();">+</button>
</div>
</td>
<td class="py-8 align-top text-right">
<p class="font-medium text-lg">{{ item.final_line_price | money }}</p>
</td>
</tr>
{% endfor %}
</tbody>
</table>
</div>
</form>
{% else %}
<div class="py-20 text-center">
    <h3 class="text-2xl serif-heading mb-4">Your cart is currently empty.</h3>
    <a href="{{ routes.all_products_collection_url }}" class="inline-block mt-4 bg-primary hover:bg-primary/90 text-white font-bold py-3 px-8 rounded-lg uppercase tracking-widest text-xs transition-all">Shop Arrivals</a>
</div>
{% endif %}
</div>

<!-- Summary Sidebar -->
<div class="w-full lg:w-[400px] flex-shrink-0">
<div class="bg-white dark:bg-background-dark/50 border border-primary/10 rounded-xl p-8 sticky top-32">
<h3 class="text-xl serif-heading mb-6">Order Summary</h3>

<!-- Free Shipping Tracker -->
<div class="mb-8">
{% assign free_shipping_threshold = 5000 %} <!-- $50.00 in cents -->
{% assign cart_total = cart.total_price %}
{% assign progress = cart_total | times: 100 | divided_by: free_shipping_threshold %}
{% if progress > 100 %}{% assign progress = 100 %}{% endif %}

<div class="flex justify-between text-sm mb-2">
<span>Shipping Progress</span>
<span class="font-medium text-primary">{{ progress }}%</span>
</div>
<div class="w-full bg-primary/10 rounded-full h-1.5 mb-2 overflow-hidden">
<div class="bg-primary h-full transition-all duration-500" style="width: {{ progress }}%;"></div>
</div>

{% if cart_total < free_shipping_threshold %}
{% assign remaining = free_shipping_threshold | minus: cart_total %}
<p class="text-xs text-brand-text/60">Spend <span class="text-primary font-bold">{{ remaining | money }}</span> more to unlock free shipping</p>
{% else %}
<p class="text-xs text-brand-text/60 font-bold text-primary">You have unlocked free shipping!</p>
{% endif %}
</div>

<div class="space-y-4 mb-8">
<div class="flex justify-between text-sm">
<span class="text-brand-text/60">Subtotal</span>
<span class="font-medium">{{ cart.items_subtotal_price | money }}</span>
</div>
<div class="flex justify-between text-sm">
<span class="text-brand-text/60">Shipping</span>
<span class="font-medium text-primary uppercase text-xs tracking-widest">Calculated at checkout</span>
</div>
{% if cart.taxes_included %}
<div class="flex justify-between text-sm">
<span class="text-brand-text/60">Taxes</span>
<span class="font-medium text-brand-text/60 text-xs">Included in total</span>
</div>
{% endif %}
<div class="pt-4 border-t border-primary/10 flex justify-between">
<span class="text-lg font-bold">Total</span>
<span class="text-lg font-bold text-primary">{{ cart.total_price | money }}</span>
</div>
</div>

<form action="{{ routes.cart_url }}" method="post" id="checkout-form">
<button type="submit" name="checkout" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-lg uppercase tracking-widest text-sm transition-all shadow-lg shadow-primary/20 active:scale-[0.98] {% if cart.item_count == 0 %}opacity-50 cursor-not-allowed{% endif %}" {% if cart.item_count == 0 %}disabled{% endif %}>
    Proceed to Checkout
</button>
</form>

<div class="mt-6 flex items-center justify-center gap-4 text-brand-text/30">
<span class="material-symbols-outlined text-xl">credit_card</span>
<span class="material-symbols-outlined text-xl">account_balance_wallet</span>
<span class="material-symbols-outlined text-xl">contactless</span>
</div>
</div>
</div>
</div>

<!-- Recommended Section -->
<section class="mt-32 pt-16 border-t border-primary/10">
<h3 class="text-3xl serif-heading mb-12 text-center">Complete The Look</h3>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
{% assign collection = collections['all'] %}
{% for product in collection.products limit: 4 %}
<div class="group cursor-pointer">
<a href="{{ product.url }}" class="relative block aspect-[3/4] bg-slate-100 rounded-xl overflow-hidden mb-4">
<img alt="{{ product.title | escape }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" src="{{ product.featured_image | image_url: width: 400 }}" width="400" height="533" loading="lazy">
<span class="absolute bottom-4 left-4 right-4 bg-white/90 backdrop-blur py-3 rounded-lg text-sm font-bold uppercase tracking-widest opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all text-center text-primary">View Product</span>
</a>
<h4 class="font-medium text-sm">{{ product.title }}</h4>
<p class="text-primary font-bold mt-1 text-sm">{{ product.price | money }}</p>
</div>
{% endfor %}
</div>
</section>
</section>

{% schema %}
{
  "name": "Cart layout",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Cart"
    }
  ],
  "presets": [
    {
      "name": "Main Cart"
    }
  ]
}
{% endschema %}
