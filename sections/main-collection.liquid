<section>
<!-- Page Title -->
<div class="mb-24 text-center px-6">
<h2 class="font-serif text-5xl md:text-7xl font-light text-brand-charcoal dark:text-slate-100">
                    {{ collection.title | default: "Our Collection" }}
                </h2>
<div class="mx-auto mt-8 h-px w-24 bg-primary/30"></div>
<p class="mt-8 text-brand-charcoal/60 dark:text-slate-400 max-w-lg mx-auto leading-relaxed">
    {{ collection.description | default: "A curated selection of timeless essentials designed for the discerning individual. Quality materials met with meticulous craftsmanship." }}
</p>
</div>

<!-- Product Grid -->
<div class="grid grid-cols-1 gap-x-8 gap-y-16 md:grid-cols-2 lg:grid-cols-3 px-6 lg:px-10 max-w-7xl mx-auto mb-20">
    {% for product in collection.products %}
        <div class="group flex flex-col">
            <a href="{{ product.url }}" class="aspect-[4/5] overflow-hidden rounded-lg bg-gray-100 block">
                <img class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}">
            </a>
            <div class="mt-6 flex flex-col items-start w-full">
                <h3 class="collection-title-caps text-brand-charcoal dark:text-slate-100">{{ product.title }}</h3>
                <p class="mt-1 text-sm text-brand-charcoal/60 dark:text-slate-400">{{ product.price | money }}</p>
                <a class="mt-3 flex items-center gap-1 text-sm font-medium text-primary transition group-hover:gap-2" href="{{ product.url }}">
                    Explore 
                    <span class="material-symbols-outlined text-base">arrow_right_alt</span>
                </a>
            </div>
        </div>
    {% else %}
        <p class="col-span-3 text-center text-slate-500 py-10">No products found in this collection.</p>
    {% endfor %}
</div>
</section>

{% schema %}
{
  "name": "Main Collection grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Main Collection"
    }
  ]
}
{% endschema %}
