<section class="max-w-7xl mx-auto px-6 lg:px-12 py-8">
<!-- Breadcrumbs -->
<nav class="flex text-xs uppercase tracking-widest text-slate-400 mb-10">
<a class="breadcrumb-item hover:text-primary" href="{{ routes.root_url }}">Home</a>
<span class="mx-2">/</span>
<a class="breadcrumb-item hover:text-primary" href="{{ routes.all_products_collection_url }}">Shop</a>
<span class="mx-2">/</span>
<span class="text-accent-dark dark:text-slate-200">{{ product.title }}</span>
</nav>

<!-- Product Grid -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
<!-- Left Column: Gallery -->
<div class="lg:col-span-7 flex flex-col md:flex-row gap-4">
    <!-- Vertical Thumbnails -->
    <div class="hidden md:flex flex-col gap-4 w-20">
        {% for image in product.images %}
        <div class="aspect-[3/4] rounded-lg overflow-hidden border border-transparent hover:border-primary/50 cursor-pointer transition-all {% if forloop.first %}border-primary{% endif %}">
            <img class="w-full h-full object-cover" src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | escape }}">
        </div>
        {% endfor %}
    </div>
    
    <!-- Main Product Image -->
    <div class="flex-1 rounded-xl overflow-hidden bg-slate-100 dark:bg-slate-800">
        <img class="w-full aspect-[4/5] object-cover hover:scale-105 transition-transform duration-700" src="{{ product.featured_image | image_url: width: 1000 }}" alt="{{ product.featured_image.alt | escape }}">
    </div>
</div>

<!-- Right Column: Product Details (Sticky) -->
<div class="lg:col-span-5 lg:sticky lg:top-32 flex flex-col gap-8">
    <div class="flex flex-col gap-2">
        {% if product.tags contains 'pack' %}
        <span class="inline-block px-3 py-1 bg-primary/10 text-primary text-[10px] font-bold uppercase tracking-widest rounded-full w-fit">Pack</span>
        {% endif %}
        <h1 class="font-serif text-4xl lg:text-5xl text-accent-dark dark:text-slate-100">{{ product.title }}</h1>
        <div class="flex items-center gap-4 mt-2">
            <span class="text-2xl font-light">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
            <span class="text-lg text-slate-400 line-through">{{ product.compare_at_price | money }}</span>
            {% endif %}
        </div>
    </div>
    
    <div class="text-slate-600 dark:text-slate-400 leading-relaxed font-light text-sm">
        {{ product.description }}
    </div>

    {% form 'product', product, id: 'product-form-installment', class: 'form flex flex-col gap-8' %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        {% unless product.has_only_default_variant %}
            <div class="flex flex-col gap-4">
                {% for option in product.options_with_values %}
                    <div class="flex flex-col gap-3">
                        <div class="flex justify-between items-center text-xs font-bold uppercase tracking-widest">
                            <span>Select {{ option.name }}</span>
                        </div>
                        <div class="grid grid-cols-3 gap-3">
                            {% for value in option.values %}
                            <label class="cursor-pointer">
                                <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" class="sr-only" {% if option.selected_value == value %}checked{% endif %}>
                                <div class="py-3 text-center border transition-colors text-sm uppercase tracking-widest
                                    {% if option.selected_value == value %} border-2 border-primary text-primary font-bold bg-primary/5 {% else %} border-slate-200 dark:border-slate-700 hover:border-primary {% endif %}
                                ">
                                    {{ value }}
                                </div>
                            </label>
                            {% endfor %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endunless %}

        <!-- Quantity & Add to Cart -->
        <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex items-center border border-slate-200 dark:border-slate-700 rounded-lg px-2 h-14">
                <button type="button" class="p-2 hover:text-primary" onclick="this.nextElementSibling.value = Math.max(1, parseInt(this.nextElementSibling.value) - 1)"><span class="material-symbols-outlined text-lg">remove</span></button>
                <input type="number" name="quantity" value="1" min="1" class="w-12 text-center font-medium bg-transparent border-none focus:ring-0 p-0" />
                <button type="button" class="p-2 hover:text-primary" onclick="this.previousElementSibling.value = parseInt(this.previousElementSibling.value) + 1"><span class="material-symbols-outlined text-lg">add</span></button>
            </div>
            
            <button type="submit" name="add" class="flex-1 h-14 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2 group {% unless product.available %}opacity-50 cursor-not-allowed{% endunless %}" {% unless product.available %}disabled{% endunless %}>
                {% if product.available %}
                    Add to Cart
                    <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                {% else %}
                    Sold Out
                {% endif %}
            </button>
        </div>
    {% endform %}

    <!-- Accordions -->
    <div class="mt-4 border-t border-slate-200 dark:border-slate-800">
        <div class="group border-b border-slate-200 dark:border-slate-800">
            <button class="w-full py-4 flex justify-between items-center text-sm font-semibold uppercase tracking-widest group-hover:text-primary transition-colors">
                Product Details
                <span class="material-symbols-outlined text-slate-400 group-hover:text-primary transition-colors">expand_more</span>
            </button>
            <div class="hidden group-focus-within:block pb-6 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                <p>Features a high-density knit that maintains shape through hundreds of washes. Perfect for the professional who values quality in every layer.</p>
            </div>
        </div>
        <div class="group border-b border-slate-200 dark:border-slate-800">
            <button class="w-full py-4 flex justify-between items-center text-sm font-semibold uppercase tracking-widest group-hover:text-primary transition-colors">
                Shipping &amp; Returns
                <span class="material-symbols-outlined text-slate-400">expand_more</span>
            </button>
        </div>
    </div>

    <!-- Trust Badges -->
    <div class="grid grid-cols-3 gap-4 pt-4 border-t border-slate-200 dark:border-slate-800">
        <div class="flex flex-col items-center text-center gap-2">
            <span class="material-symbols-outlined text-primary text-2xl">verified</span>
            <span class="text-[10px] font-bold uppercase tracking-tight opacity-70">100% Cotton</span>
        </div>
        <div class="flex flex-col items-center text-center gap-2">
            <span class="material-symbols-outlined text-primary text-2xl">eco</span>
            <span class="text-[10px] font-bold uppercase tracking-tight opacity-70">Ethically Made</span>
        </div>
        <div class="flex flex-col items-center text-center gap-2">
            <span class="material-symbols-outlined text-primary text-2xl">air</span>
            <span class="text-[10px] font-bold uppercase tracking-tight opacity-70">Anti-Odour</span>
        </div>
    </div>
</div>
</div>
</section>

{% schema %}
{
  "name": "Product Information",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product"
    }
  ],
  "presets": [
    {
      "name": "Product Information"
    }
  ]
}
{% endschema %}
