
<section>
<div class="max-w-5xl w-full bg-white dark:bg-background-dark/50 rounded-xl shadow-xl overflow-hidden flex flex-col md:flex-row min-h-[600px]">
<div class="flex-1 p-8 md:p-16 flex flex-col justify-center border-b md:border-b-0 md:border-r border-neutral-soft/30">
<div class="max-w-sm mx-auto w-full">
<h2 class="font-serif text-3xl md:text-4xl text-slate-900 dark:text-slate-100 mb-2">Welcome Back</h2>
<p class="text-slate-500 dark:text-slate-400 text-sm mb-10">Sign in to your account to continue.</p>
<form class="space-y-8">
<div class="group">
<label class="block text-xs font-semibold uppercase tracking-widest text-slate-400 mb-1 group-focus-within:text-primary transition-colors" for="email">Email Address</label>
<input class="input-minimal w-full py-2 text-slate-900 dark:text-slate-100 text-base" id="email" name="email" placeholder="hello@example.com" type="email">
</div>
<div class="group relative">
<label class="block text-xs font-semibold uppercase tracking-widest text-slate-400 mb-1 group-focus-within:text-primary transition-colors" for="password">Password</label>
<input class="input-minimal w-full py-2 text-slate-900 dark:text-slate-100 text-base" id="password" name="password" placeholder="••••••••" type="password">
<button class="absolute bottom-2 right-0 text-slate-400 hover:text-primary" type="button">
<span class="material-symbols-outlined text-[20px]">visibility</span>
</button>
</div>
<div class="flex items-center justify-between pt-2">
<label class="flex items-center gap-2 cursor-pointer group">
<input class="rounded border-neutral-soft text-primary focus:ring-primary w-4 h-4" type="checkbox">
<span class="text-sm text-slate-500 group-hover:text-slate-700 dark:group-hover:text-slate-300 transition-colors">Stay signed in</span>
</label>
<a class="text-sm text-slate-400 hover:text-primary transition-colors underline underline-offset-4 decoration-slate-200 hover:decoration-primary" href="{{ routes.all_products_collection_url }}">Forgot?</a>
</div>
<button class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-lg shadow-lg shadow-primary/20 transition-all active:scale-[0.98] mt-4 uppercase tracking-widest text-sm" type="submit">
                            Sign In
                        </button>
</form>
<div class="mt-8 flex items-center gap-4">
<div class="h-[1px] flex-1 bg-neutral-soft/50"></div>
<span class="text-xs text-slate-400 uppercase tracking-widest">or connect with</span>
<div class="h-[1px] flex-1 bg-neutral-soft/50"></div>
</div>
<div class="mt-6 grid grid-cols-2 gap-4">
<button class="flex items-center justify-center gap-2 py-3 border border-neutral-soft rounded-lg hover:bg-background-light dark:hover:bg-slate-800 transition-colors">
<img alt="Google logo" class="w-5 h-5" data-alt="Google colorful logo icon" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAXEBTylZlfE-ZsgeU1fIOveg8aq3NZKiau79ZBckmOHRTfpKP-bzdyuPtzKQQxAiTHruSfTO-ooX-Q8IyidRKs1IPoeSZ2L5c2ntUxDYjJETW46Tp6lq_Iznk18mjUIm2ZxqoB4S3UY9Qo4RZ3fJoUdMjr8aXJrnuollauZO3x-aMzRgFw16lDDg4tnufD7L6-fMBWZ8xOEMgZ00xdM9XV73xVH0n7ry2q9PdmVpSYWBfv9ypD8oJJXIuZ-8lTDh9DYrtjP4t6C6E">
<span class="text-sm font-medium">Google</span>
</button>
<button class="flex items-center justify-center gap-2 py-3 border border-neutral-soft rounded-lg hover:bg-background-light dark:hover:bg-slate-800 transition-colors">
<img alt="Apple logo" class="w-5 h-5 dark:invert" data-alt="Apple monochrome logo icon" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCgwdGk5BPItIMCZOo5EoW_JkITDt1qw088TCBvBz2BiCFTTS6xw4ifAXUkIsFz7I4V3zKaAuuZqVWgZQ8Sndp5Wwiw1a25GhuTudopDsLKiVFRno_NrMcsyNcGjuHUU71-iNI8NsAnfVaayjIgdTkmvgEtvtcALNcQ-iWbEKapydMW5twOZ7hebeaf6ixbHgJ53c_XBKzZWWFVsw7FcisEIWhHzl8iOuJZEHqq7l-tv8Fy0v7T9M0f_7iz9VykA9N47HDHycF_YsM">
<span class="text-sm font-medium">Apple</span>
</button>
</div>
</div>
</div>
<div class="flex-1 bg-primary/5 dark:bg-primary/10 p-8 md:p-16 flex flex-col justify-center items-center text-center">
<div class="max-w-sm">
<div class="mb-8 hidden md:block">
<div class="w-24 h-24 mx-auto bg-primary/20 rounded-full flex items-center justify-center text-primary mb-6">
<span class="material-symbols-outlined text-[48px]">auto_awesome</span>
</div>
</div>
<h2 class="font-serif text-3xl md:text-4xl text-slate-900 dark:text-slate-100 mb-6">New Here?</h2>
<p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed mb-10">
                        Join our community of intentional adults. Get exclusive access to tools, resources, and a supportive network designed for the modern lifestyle.
                    </p>
<ul class="text-left space-y-4 mb-10 max-w-[280px] mx-auto">
<li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-400">
<span class="material-symbols-outlined text-primary text-[18px]">check_circle</span>
<span>Personalized growth tracks</span>
</li>
<li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-400">
<span class="material-symbols-outlined text-primary text-[18px]">check_circle</span>
<span>Monthly physical toolkits</span>
</li>
<li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-400">
<span class="material-symbols-outlined text-primary text-[18px]">check_circle</span>
<span>Members-only digital hub</span>
</li>
</ul>
<button class="w-full border-2 border-primary text-primary hover:bg-primary hover:text-white font-bold py-4 rounded-lg transition-all active:scale-[0.98] uppercase tracking-widest text-sm">
                        Create Account
                    </button>
</div>
</div>
</div>
</section>

